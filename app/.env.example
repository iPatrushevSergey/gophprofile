# Defaults: internal/server/config and internal/processor/config (setDefaults).
# Config files: app/configs/server.yaml and app/configs/processor.yaml (override defaults path via CONFIG).
# This .env overrides both code defaults and config file values.
# Flags override this .env.

# --- server ---

# CONFIG=app/configs/server.yaml

# GOPHPROFILE_DATABASE_URI=postgres://user:password@localhost:5432/gophprofile?sslmode=disable

# GOPHPROFILE_SERVER_ADDRESS=127.0.0.1:8080
# GOPHPROFILE_LOGGER_LEVEL=info
# GOPHPROFILE_TELEMETRY_ENABLED=false
# GOPHPROFILE_TELEMETRY_OTLP_ENDPOINT=localhost:4317
# GOPHPROFILE_TELEMETRY_OTLP_INSECURE=true
# GOPHPROFILE_TELEMETRY_SAMPLE_RATIO=1.0
# GOPHPROFILE_TELEMETRY_ENVIRONMENT=development
# GOPHPROFILE_MINIO_ENDPOINT=127.0.0.1:9000
# GOPHPROFILE_MINIO_ACCESS_KEY=minioadmin
# GOPHPROFILE_MINIO_SECRET_KEY=minioadmin
# GOPHPROFILE_BROKER_URL=amqp://gophprofile:gophprofile@localhost:5672/
# RabbitMQ topology: deploy/rabbitmq/definitions.json (loaded by docker compose rabbitmq service)
# GOPHPROFILE_SERVER_CERT_FILE=certs/server.crt
# GOPHPROFILE_SERVER_KEY_FILE=certs/server.key

# --- processor ---

# CONFIG=app/configs/processor.yaml

# GOPHPROFILE_DATABASE_URI=postgres://user:password@localhost:5432/gophprofile?sslmode=disable
# GOPHPROFILE_MINIO_ENDPOINT=127.0.0.1:9000
# GOPHPROFILE_MINIO_ACCESS_KEY=minioadmin
# GOPHPROFILE_MINIO_SECRET_KEY=minioadmin
# GOPHPROFILE_BROKER_URL=amqp://gophprofile:gophprofile@localhost:5672/
# RabbitMQ topology: deploy/rabbitmq/definitions.json (loaded by docker compose rabbitmq service)
# GOPHPROFILE_LOGGER_LEVEL=info
# GOPHPROFILE_TELEMETRY_ENABLED=false
# GOPHPROFILE_TELEMETRY_OTLP_ENDPOINT=localhost:4317
# GOPHPROFILE_TELEMETRY_OTLP_INSECURE=true
# GOPHPROFILE_TELEMETRY_SAMPLE_RATIO=1.0
# GOPHPROFILE_TELEMETRY_ENVIRONMENT=development
