# Docker Compose — copy to repo root: cp .env.example .env
# docker compose reads .env automatically; do not commit .env.

# PostgreSQL
POSTGRES_USER=gophprofile
POSTGRES_PASSWORD=gophprofile
POSTGRES_DB=gophprofile

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=gophprofile

# RabbitMQ
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# App (server / processor) — non-secret defaults
GOPHPROFILE_MINIO_USE_SSL=false
GOPHPROFILE_SERVER_ADDRESS=0.0.0.0:8080
