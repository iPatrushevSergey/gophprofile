FROM golang:1.26-alpine AS builder

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 go build -tags=go_json -o /out/server ./app/cmd/server

FROM alpine:3.21

RUN apk add --no-cache ca-certificates

WORKDIR /app

COPY --from=builder /out/server /app/server
COPY --from=builder /src/migrations /src/migrations
COPY app/configs/server.yaml /app/configs/server.yaml

EXPOSE 8080

ENTRYPOINT ["/app/server", "-c", "/app/configs/server.yaml"]
